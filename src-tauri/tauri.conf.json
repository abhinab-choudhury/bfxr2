{
  "productName": "Bfxr2",
  "version": "1.0.0",
  "identifier": "net.bfxr.desktop",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Bfxr2",
        "width": 1200,
        "height": 800,
        "url": "https://bfxr2.vercel.app/",
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
